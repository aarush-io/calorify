rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Foods subcollection
      match /foods/{foodId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Daily logs subcollection
      match /dailyLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
