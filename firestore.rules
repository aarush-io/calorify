rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Users can read their own doc freely
      allow read: if request.auth != null && request.auth.uid == userId;

      // Users can write their own doc EXCEPT for AI quota fields.
      // aiScansUsed, plan, and subscriptionStatus are server-only — only
      // Firebase Functions (admin SDK) may change them.
      allow write: if request.auth != null
        && request.auth.uid == userId
        && !("aiScansUsed"        in request.resource.data.diff(resource.data).affectedKeys())
        && !("plan"               in request.resource.data.diff(resource.data).affectedKeys())
        && !("subscriptionStatus" in request.resource.data.diff(resource.data).affectedKeys())
        && !("aiScansLimit"       in request.resource.data.diff(resource.data).affectedKeys());

      // Foods subcollection
      match /foods/{foodId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Daily logs subcollection
      match /dailyLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
